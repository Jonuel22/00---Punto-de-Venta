{
  "name": "punto-de-venta-jctechnology",
  "version": "1.0.0",
  "description": "Sistema de Punto de Venta - JCTechnology",
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "build": "electron-builder --win --x64",
    "build:dir": "electron-builder --win --x64 --dir"
  },
  "keywords": [],
  "author": "JCTechnology",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "body-parser": "^1.20.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "mysql": "^2.18.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.jctechnology.puntoventa",
    "productName": "Punto de Venta JCTechnology",
    "asar": true,
    "asarUnpack": [
      "server.js",
      "routes/**/*",
      "public/**/*",
      "*.html",
      "*.css",
      "*.js",
      "LOGO.jpg",
      "LOGO.ico",
      "images/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "LOGO.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerHeaderIcon": "LOGO.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Punto de Venta"
    },
    "files": [
      "**/*",
      "!node_modules/.cache",
      "!*.md",
      "!_git*"
    ],
    "extraResources": [],
    "directories": {
      "output": "dist"
    }
  }
}